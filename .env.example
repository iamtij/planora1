# Copy to .env and adjust.
# Docker (recommended if you use docker-compose): port 5433 to avoid clashing with Homebrew Postgres on 5432.
# DATABASE_URL=postgresql://postgres:postgres@localhost:5433/planorama
# Homebrew / local Postgres (macOS user is often your login name, no password on localhost):
# DATABASE_URL=postgresql://YOUR_USER@localhost:5432/planorama
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/planorama

# --- Railway Postgres (production) ---
# In Railway, set DATABASE_URL from the Postgres plugin (or paste below with your password).
# The API enables TLS for *.rlwy.net hosts (proxy certificate).
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@caboose.proxy.rlwy.net:49447/railway
# Copy the Postgres plugin "DATABASE_URL" into RAILWAY_DATABASE_URL for migrations:
# RAILWAY_DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@caboose.proxy.rlwy.net:49447/railway
# Then: npm run db:migrate:railway

# API server port (Vite proxies /api here in dev)
API_PORT=3001

# Admin (/admin) — set strong secrets in production
# On Railway/Render: add these three on the *web* service Variables tab (not only Postgres), then redeploy.
ADMIN_USERNAME=planoadmin
ADMIN_PASSWORD=change_me
ADMIN_JWT_SECRET=replace_with_a_long_random_hex_or_string

# --- Booking emails (Resend: https://resend.com — get an API key, optional verified domain) ---
# Without RESEND_API_KEY, bookings still save but no emails are sent (see server logs).
# After setting RESEND_API_KEY, run: npm run mail:test   (or: npm run mail:test -- --both)
RESEND_API_KEY=re_your_resend_api_key
# From address (use a verified domain in Resend, or their onboarding/sandbox sender while testing)
EMAIL_FROM=Planorama <onboarding@resend.dev>
# Where new booking notifications go
ADMIN_NOTIFY_EMAIL=you@example.com
# Public site URL for links in admin notification emails (no trailing slash)
PUBLIC_APP_URL=http://localhost:3000
# Test flow: book with a test inbox as the form email; approve in /admin/inquiries
